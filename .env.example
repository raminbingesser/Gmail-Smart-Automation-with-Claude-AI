# Claude API (https://console.anthropic.com/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth Credentials (Gmail — nur für Ramin)
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
GOOGLE_TOKEN_PATH=credentials/token.json

# Hotmail IMAP (für zweiten Nutzer — install.sh befüllt das automatisch)
HOTMAIL_EMAIL=name@hotmail.ch
HOTMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Microsoft App-Passwort (nicht normales Login)
HOTMAIL_IMAP_SERVER=outlook.office365.com
HOTMAIL_IMAP_PORT=993

# Classifier Config
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
EMAILS_PER_RUN=100
